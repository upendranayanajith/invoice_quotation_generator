# Firebase Configuration (Required for database connection)
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# Company Information
NEXT_PUBLIC_COMPANY_NAME="Acme Corp"
NEXT_PUBLIC_COMPANY_ADDRESS="123 Example Street, City, Country"
NEXT_PUBLIC_COMPANY_EMAIL="contact@example.com"
NEXT_PUBLIC_COMPANY_PHONE="+1 234 567 8900"
NEXT_PUBLIC_COMPANY_REG_NO="REG-12345678"

# Bank Details
NEXT_PUBLIC_BANK_NAME="Example Bank"
NEXT_PUBLIC_BANK_ACCOUNT_NAME="Acme Corp Account"
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER="1234567890"
NEXT_PUBLIC_BANK_BRANCH="Main Branch"

# Assets
NEXT_PUBLIC_COMPANY_LOGO_PATH="/placeholder-logo.png"
